# Rebrand theme to Midnight Sand palette

# ---- app_theme.dart ----
p = 'lib/core/theme/app_theme.dart'
s = open(p).read()

s = """import 'package:flutter/material.dart';

class AppTheme {
  AppTheme._();

  // Midnight Sand palette
  static const Color tealBlue = Color(0xFF4A8FA8);
  static const Color warmSand = Color(0xFFC4A882);
  static const Color lightText = Color(0xFFE8DDD3);
  static const Color darkBase = Color(0xFF121212);
  static const Color darkCard = Color(0xFF1E1E1E);

  // Light Coastal palette (for light mode)
  static const Color sandWhite = Color(0xFFFAF6F1);
  static const Color driftwood = Color(0xFFE8DDD3);
  static const Color deepBlue = Color(0xFF2C5F7C);

  static ThemeData get lightTheme => ThemeData(
        useMaterial3: true,
        colorScheme: const ColorScheme.light(
          primary: deepBlue,
          onPrimary: sandWhite,
          primaryContainer: Color(0xFFD0E8F2),
          onPrimaryContainer: deepBlue,
          secondary: warmSand,
          onSecondary: darkBase,
          surface: sandWhite,
          onSurface: darkBase,
          surfaceContainerHighest: driftwood,
          onSurfaceVariant: Color(0xFF5C4033),
          error: Color(0xFFB3261E),
          onError: Colors.white,
        ),
        scaffoldBackgroundColor: sandWhite,
        appBarTheme: const AppBarTheme(
          backgroundColor: sandWhite,
          foregroundColor: deepBlue,
          elevation: 0,
        ),
        cardTheme: CardThemeData(
          color: Colors.white,
          elevation: 0,
          shape: RoundedRectangleBorder(
            borderRadius: BorderRadius.circular(14),
            side: const BorderSide(color: driftwood),
          ),
        ),
        floatingActionButtonTheme: const FloatingActionButtonThemeData(
          backgroundColor: deepBlue,
          foregroundColor: sandWhite,
        ),
      );

  static ThemeData get darkTheme => ThemeData(
        useMaterial3: true,
        colorScheme: const ColorScheme.dark(
          primary: tealBlue,
          onPrimary: darkBase,
          primaryContainer: Color(0xFF1A3A4A),
          onPrimaryContainer: lightText,
          secondary: warmSand,
          onSecondary: darkBase,
          surface: darkBase,
          onSurface: lightText,
          surfaceContainerHighest: Color(0xFF2A2A2A),
          onSurfaceVariant: warmSand,
          error: Color(0xFFCF6679),
          onError: darkBase,
        ),
        scaffoldBackgroundColor: darkBase,
        appBarTheme: const AppBarTheme(
          backgroundColor: darkBase,
          foregroundColor: lightText,
          elevation: 0,
        ),
        cardTheme: CardThemeData(
          color: darkCard,
          elevation: 0,
          shape: RoundedRectangleBorder(
            borderRadius: BorderRadius.circular(14),
            side: BorderSide.none,
          ),
        ),
        floatingActionButtonTheme: const FloatingActionButtonThemeData(
          backgroundColor: tealBlue,
          foregroundColor: lightText,
        ),
      );
}
"""

open(p, 'w').write(s)
print('app_theme.dart patched')

# ---- app.dart: default to dark mode ----
p2 = 'lib/app.dart'
s2 = open(p2).read()
s2 = s2.replace('themeMode: ThemeMode.system', 'themeMode: ThemeMode.dark')
open(p2, 'w').write(s2)
print('app.dart patched to dark mode default')
